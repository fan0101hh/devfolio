# ========================================
# 复制本文件为 .env 并修改以下配置
# cp .env.example .env
# ========================================

# ── 数据库 ──
DEVFOLIO_DB_USERNAME=devfolio
DEVFOLIO_DB_PASSWORD=your-db-password-here
MYSQL_ROOT_PASSWORD=your-root-password-here

# ── 管理员 ──
DEVFOLIO_ADMIN_USERNAME=admin
# 必须填 BCrypt hash，不是明文密码！
# 生成方法（任选其一）：
#   python3 -c "import bcrypt; print(bcrypt.hashpw(b'your-password', bcrypt.gensalt()).decode())"
#   htpasswd -nbBC 10 "" your-password | cut -d: -f2
#   或使用在线 BCrypt 生成器
# 下面这个是 "change-me-now" 的 hash，请替换：
DEVFOLIO_ADMIN_PASSWORD=$2a$10$dN9vEFwTHeDfNMh9iZyBnu6PMqFMFJp9H8rWbFLOSc6TCXwGr/vSi

# ── JWT ──
# 至少 32 字符的随机字符串，可用以下命令生成：
#   openssl rand -base64 48
DEVFOLIO_JWT_SECRET=your-jwt-secret-at-least-32-bytes-long
